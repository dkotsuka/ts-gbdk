{
  "name": "ts-gbdk-sdk",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "description": "TypeScript SDK that transpiles to C for GBDK-2020",
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "dev": "tsc -b -w",
    "lint": "tsc -b --pretty false",
    "test": "npm run build && npm test --workspace=packages/compiler"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.5"
  }
}
